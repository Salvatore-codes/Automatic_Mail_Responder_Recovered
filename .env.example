# Trofeo Hardware Email Ingestion Configuration
# Copy this file to '.env' and fill in your credentials

# IMAP Settings (to poll incoming emails)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# SMTP Settings (to send outgoing quotes)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# Account Credentials
# Note: For Gmail, use an App Password (not your main password)
EMAIL_USER=your_store_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Gemini Settings (for Scenario B AI features)
GEMINI_API_KEY=your_gemini_api_key

# Business Profile Settings
BUSINESS_NAME=Trofeo Solution
SALES_EXECUTIVE_NAME=Rajaram
SALES_EXECUTIVE_TITLE=Sales Executive
SALES_EXECUTIVE_PHONE=+91 98765 43210
SALES_EXECUTIVE_EMAIL=sales@trofeosolution.com

# Payment Gateway (UPI Deep Link)
UPI_ID=merchant@bank
UPI_MERCHANT_NAME=Trofeo Hardware

# Master User Notification Settings
MASTER_EMAIL=master_admin@gmail.com

